{
    "manifest_version": 3,
    "browser_specific_settings": {
        "gecko": {
            "id": "newweb@example.com",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "name": "New WEB",
    "version": "4.0.0",
    "description": "A premium, privacy-focused new tab experience with search, AI mode, weather, and favourite sites.",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": [
        "storage",
        "topSites"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none';"
    },
    "icons": {
        "16": "icons/icon.svg",
        "48": "icons/icon.svg",
        "128": "icons/icon.svg"
    },
    "host_permissions": [
        "https://api.open-meteo.com/*",
        "https://nominatim.openstreetmap.org/*",
        "https://duckduckgo.com/*",
        "https://suggestqueries.google.com/*"
    ]
}